node_modules/
dist/
.env
*.bak
data/db.json
.idea/
dist-package/
my-openclaw-*-dist.tar.gz

# ClawHub CLI state directory (lock.json 等)
.clawhub/

# Vite dev server log
ui-dev.log

# TypeScript incremental build files
*.tsbuildinfo

# 项目使用 yarn，忽略 npm 生成的 lock 避免冲突
package-lock.json

# 用户聊天数据（隐私 + 体积大，不应进入仓库）
data/chats/

# 后端 runtime 数据：用户会话事件 + 数据库
# 这些是运行期持续累积的状态，不应进入版本控制
backend/data/db.json
backend/data/session-events.jsonl

# 后端 dev log（PowerShell 重定向写入，UTF-16 LE 编码，不应进版本控制）
backend/dev.log

# yarn 错误日志（yarn install 失败时产生）
*-error.log
